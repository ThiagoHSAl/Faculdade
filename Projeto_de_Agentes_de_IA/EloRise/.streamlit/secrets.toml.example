# Ative o "Entrar com Google" copiando este arquivo para .streamlit/secrets.toml
# e preenchendo com um OAuth Client do Google Cloud (tipo "Web application"):
#   1. https://console.cloud.google.com/apis/credentials → Create credentials → OAuth client ID
#   2. Authorized redirect URI: http://localhost:8501/oauth2callback
#      (no deploy: https://SEU-APP.streamlit.app/oauth2callback — cadastre as DUAS)
#   3. Cole client_id/client_secret abaixo e gere um cookie_secret aleatório, ex.:
#      python3 -c "import secrets; print(secrets.token_hex(32))"
# O secrets.toml NUNCA vai para o git (está no .gitignore). No Streamlit Community
# Cloud, cole este MESMO conteúdo no painel do app (Settings → Secrets), trocando a
# redirect_uri pela do deploy.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "TROQUE_POR_UM_HEX_ALEATORIO_LONGO"
client_id = "SEU_CLIENT_ID.apps.googleusercontent.com"
client_secret = "SEU_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Persistência em Postgres (Supabase) — OBRIGATÓRIO no Streamlit Community Cloud
# (o disco de lá é efêmero; um SQLite zeraria contas e conversas a cada redeploy).
# Use a connection string do POOLER do Supabase (Session pooler, porta 5432 — é IPv4;
# a conexão direta é só IPv6 e não funciona no Streamlit Cloud).
# Sem esta chave, o app usa o SQLite local (elorise.db) — ideal para rodar na máquina.
# DATABASE_URL = "postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Chaves que o app lê do ambiente (no deploy não existe o arquivo .env; o app.py copia
# esta seção para variáveis de ambiente na inicialização).
[env]
RIOT_API_KEY = "RGAPI-..."
GEMINI_API_KEY = "AIza..."
# BENCHMARKS_API_URL = "http://129.80.151.220:8000"  # default já aponta para a VPS
